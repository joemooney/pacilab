{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pacinet.dev/schemas/pacilab/scenario_v1.schema.json",
  "title": "paciLab Scenario v1",
  "type": "object",
  "required": ["id", "name", "events"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "enum": ["v1", "v2"] },
    "id": { "type": "string", "minLength": 1, "pattern": "^[A-Za-z0-9_.-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "description": { "type": "string" },
    "default_rules_file": { "type": "string", "minLength": 1 },
    "stateful": { "type": "boolean" },
    "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "packet"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "packet": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "oneOf": [
                { "type": "string" },
                { "type": "integer" },
                { "type": "number" },
                { "type": "boolean" }
              ]
            }
          },
          "expected_action": { "type": "string", "enum": ["pass", "drop"] },
          "delay_ms": { "type": "integer", "minimum": 0 },
          "meta": { "type": "object", "additionalProperties": true }
        }
      }
    }
  }
}
